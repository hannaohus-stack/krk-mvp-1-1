---
interface Props {
  title: string
  description?: string
  ogImage?: string
  canonicalUrl?: string
}
const {
  title,
  description = '스몰 식품 브랜드를 위한 표시 기준 가이드. 판매 전 라벨을 자율 점검하세요.',
  ogImage = 'https://blog.krk.team/og-default.png',
  canonicalUrl,
} = Astro.props

const siteUrl = 'https://blog.krk.team'
const canonical = canonicalUrl ?? siteUrl + Astro.url.pathname
---

<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- OG / Twitter -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="KRK Checker 블로그" />
  <meta name="twitter:card"       content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
  />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html, body {
      margin: 0; padding: 0;
      font-family: 'Pretendard', 'Pretendard Variable', system-ui, -apple-system, sans-serif;
      color: #0A0A0B;
      background: #fff;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    ::selection { background: #0CA4F9; color: #fff; }
    a { color: inherit; }
    img { max-width: 100%; display: block; }

    /* Prose styles for MDX article body */
    .krk-prose {
      font-size: 16px;
      line-height: 1.85;
      color: #0A0A0B;
      letter-spacing: -0.01em;
    }
    .krk-prose p  { margin: 0 0 22px; }
    .krk-prose h2 {
      font-size: clamp(20px, 2.5vw, 24px);
      font-weight: 700;
      line-height: 1.35;
      letter-spacing: -0.025em;
      margin: 56px 0 18px;
      padding-top: 24px;
      border-top: 1px solid rgba(10,10,11,0.10);
      display: flex; align-items: baseline; gap: 14px;
    }
    .krk-prose h3 {
      font-size: clamp(17px, 2vw, 19px);
      font-weight: 600;
      line-height: 1.4;
      letter-spacing: -0.02em;
      margin: 36px 0 12px;
    }
    .krk-prose ul, .krk-prose ol {
      margin: 0 0 22px;
      padding-left: 0;
      list-style: none;
    }
    .krk-prose li {
      padding-left: 22px;
      position: relative;
      font-size: 15.5px;
      line-height: 1.8;
      letter-spacing: -0.01em;
      margin-bottom: 6px;
    }
    .krk-prose li::before {
      content: '—';
      position: absolute; left: 0; top: 0;
      color: #002D72; font-weight: 600;
    }
    .krk-prose ol { counter-reset: item; }
    .krk-prose ol li::before {
      content: counter(item, decimal-leading-zero);
      counter-increment: item;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 11px; font-weight: 600;
      color: #002D72; letter-spacing: 0.04em;
      top: 4px;
    }
    .krk-prose blockquote {
      margin: 28px 0;
      padding: 20px 24px;
      background: #F6F9FD;
      border: 1px solid rgba(12,164,249,0.2);
      border-left: 3px solid #0CA4F9;
      font-size: 14.5px;
      line-height: 1.7;
      letter-spacing: -0.005em;
    }
    .krk-prose blockquote p { margin: 0; }
    .krk-prose table {
      width: 100%; border-collapse: collapse;
      margin: 28px 0;
      font-size: 14px;
      letter-spacing: -0.005em;
    }
    .krk-prose th {
      text-align: left;
      padding: 10px 14px;
      background: #F4F4F5;
      border: 1px solid rgba(10,10,11,0.10);
      font-weight: 600;
      font-size: 12px;
      letter-spacing: 0.02em;
    }
    .krk-prose td {
      padding: 10px 14px;
      border: 1px solid rgba(10,10,11,0.10);
      line-height: 1.6;
    }
    .krk-prose strong { font-weight: 700; }
    .krk-prose code {
      font-family: 'Inter', monospace;
      font-size: 13px;
      background: #F4F4F5;
      padding: 2px 6px;
      border: 1px solid rgba(10,10,11,0.10);
    }
    .krk-prose a {
      color: #002D72;
      text-decoration: underline;
      text-decoration-color: rgba(0,45,114,0.3);
      text-underline-offset: 3px;
    }
    .krk-prose a:hover { text-decoration-color: #002D72; }
    .krk-prose hr {
      border: none;
      border-top: 1px solid rgba(10,10,11,0.10);
      margin: 48px 0;
    }

    @media (max-width: 760px) {
      .krk-prose { font-size: 15px; }
      .krk-prose h2 { margin: 40px 0 14px; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
