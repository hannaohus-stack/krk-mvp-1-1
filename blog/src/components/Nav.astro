---
interface Props {
  currentPath?: string
}
const { currentPath = '/' } = Astro.props
---

<nav class="krk-nav">
  <div class="krk-nav-inner">
    <div class="krk-nav-left">
      <a href="/" class="krk-logo">
        KRK CHECKER<span class="krk-logo-dot">·</span>
      </a>
      <div class="krk-nav-links">
        <a href="/" class:list={['krk-nav-link', { active: currentPath === '/' }]}>블로그</a>
      </div>
    </div>
    <a href="https://checker.krk.team" class="krk-nav-cta">
      라벨 검토 시작하기
    </a>
  </div>
  <div class="krk-nav-glow"></div>
</nav>

<style>
  .krk-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 60;
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border-bottom: 1px solid rgba(10,10,11,0.06);
  }
  .krk-nav-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 18px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .krk-nav-left {
    display: flex;
    align-items: baseline;
    gap: 28px;
  }
  .krk-logo {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #0A0A0B;
    text-decoration: none;
    line-height: 1;
  }
  .krk-logo-dot { color: #0CA4F9; margin-left: 0.18em; }
  .krk-nav-links {
    display: flex;
    gap: 24px;
    font-size: 13px;
    color: rgba(10,10,11,0.55);
  }
  .krk-nav-link {
    text-decoration: none;
    color: rgba(10,10,11,0.55);
    font-weight: 400;
    transition: color 160ms;
  }
  .krk-nav-link.active,
  .krk-nav-link:hover {
    color: #0A0A0B;
    font-weight: 600;
  }
  .krk-nav-cta {
    padding: 10px 18px;
    background: #0A0A0B;
    color: #fff;
    text-decoration: none;
    font-family: 'Pretendard', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: -0.005em;
    white-space: nowrap;
    transition: opacity 160ms;
  }
  .krk-nav-cta:hover { opacity: 0.85; }
  .krk-nav-glow {
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(12,164,249,0.42), transparent);
  }
  @media (max-width: 760px) {
    .krk-nav-inner { padding: 14px 20px; }
    .krk-logo { font-size: 12px; }
    .krk-nav-links { display: none; }
    .krk-nav-cta { padding: 8px 14px; font-size: 12px; }
  }
</style>
