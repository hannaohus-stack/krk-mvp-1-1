---
interface Props {
  kind: string
  tone?: 'light' | 'dark'
}
const { kind, tone = 'light' } = Astro.props

const light = { a:'#DCE9F4', b:'#BBD3E8', c:'#9DD6FB', d:'#3AB2FA', e:'#002D72' }
const dark  = { a:'#001D4A', b:'#002D72', c:'#0CA4F9', d:'#9DD6FB', e:'#FFFFFF' }
const p = tone === 'dark' ? dark : light
const bg = tone === 'dark'
  ? `radial-gradient(120% 90% at 30% 30%, ${p.b} 0%, ${p.a} 60%, #000B1F 100%)`
  : `radial-gradient(120% 90% at 30% 30%, #FFF 0%, ${p.a} 45%, ${p.b} 100%)`
const stroke = tone === 'dark' ? p.d : p.e
const accent = tone === 'dark' ? p.c : p.d
const sw = '1.2'
const fillSoft = tone === 'dark' ? 'rgba(255,255,255,0.08)' : 'rgba(0,45,114,0.08)'
const border = tone === 'dark' ? 'rgba(255,255,255,0.06)' : 'rgba(10,10,11,0.10)'
---

<div class="krk-thumb" style={`background:${bg};border-bottom:1px solid ${border}`}>
  <svg viewBox="0 0 200 150" aria-hidden="true">
    {kind === 'grid' && (
      <>
        {[0,1,2].map(r => [0,1,2].map(c => (
          <rect x={62+c*26} y={37+r*26} width="22" height="22" stroke={stroke} stroke-width={sw} fill="none" stroke-linecap="square" />
        )))}
        <rect x="62" y="37" width="22" height="22" fill={accent} opacity="0.85" />
        <rect x="114" y="89" width="22" height="22" fill={accent} opacity="0.45" />
      </>
    )}
    {kind === 'orbit' && (
      <>
        <ellipse cx="100" cy="75" rx="60" ry="22" stroke={stroke} stroke-width={sw} fill="none"/>
        <ellipse cx="100" cy="75" rx="44" ry="16" stroke={stroke} stroke-width={sw} fill="none"/>
        <ellipse cx="100" cy="75" rx="26" ry="9"  stroke={stroke} stroke-width={sw} fill="none"/>
        <circle cx="100" cy="75" r="3"   fill={accent}/>
        <circle cx="160" cy="75" r="2.5" fill={accent}/>
        <circle cx="40"  cy="75" r="2.5" fill={accent} opacity="0.5"/>
      </>
    )}
    {kind === 'arc' && (
      <>
        {Array.from({length:11}).map((_,i) => {
          const a = (Math.PI/10)*i
          const x1=100+Math.cos(Math.PI+a)*40, y1=115+Math.sin(Math.PI+a)*40
          const x2=100+Math.cos(Math.PI+a)*56, y2=115+Math.sin(Math.PI+a)*56
          return <line x1={x1} y1={y1} x2={x2} y2={y2} stroke={i===3?accent:stroke} stroke-width={i===3?'2':'1'} opacity={i===3?'1':'0.45'} />
        })}
        <path d="M 44 115 A 56 56 0 0 1 156 115" stroke={stroke} stroke-width={sw} fill="none"/>
      </>
    )}
    {kind === 'bars' && (
      <>
        {[44,28,56,36,68].map((h,i) => (
          <rect x={50+i*22} y={110-h} width="14" height={h} stroke={stroke} stroke-width={sw} fill="none"/>
        ))}
        <rect x="94" y="54" width="14" height="56" fill={accent} opacity="0.85"/>
        <line x1="40" y1="110" x2="160" y2="110" stroke={stroke} stroke-width={sw}/>
      </>
    )}
    {kind === 'tri' && (
      <>
        <polygon points="100,40 140,110 60,110" stroke={stroke} stroke-width={sw} fill="none"/>
        <polygon points="100,48 130,102 70,102" fill={fillSoft}/>
        <circle cx="100" cy="75" r="2.5" fill={accent}/>
      </>
    )}
    {kind === 'split' && (
      <>
        <rect x="68" y="32" width="64" height="38" stroke={stroke} stroke-width={sw} fill="none"/>
        <rect x="60" y="74" width="80" height="42" stroke={stroke} stroke-width={sw} fill="none"/>
        <line x1="60" y1="74" x2="140" y2="74" stroke={stroke} stroke-width={sw} stroke-dasharray="3 3"/>
        <rect x="60" y="74" width="80" height="42" fill={fillSoft}/>
      </>
    )}
    {kind === 'frame' && (
      <>
        <rect x="44" y="36" width="112" height="78" stroke={stroke} stroke-width={sw} fill="none"/>
        <rect x="44" y="36" width="112" height="14" fill={accent} opacity="0.85"/>
        <line x1="56" y1="62" x2="144" y2="62" stroke={stroke} stroke-width={sw}/>
        <line x1="56" y1="72" x2="124" y2="72" stroke={stroke} stroke-width={sw}/>
        <line x1="56" y1="82" x2="138" y2="82" stroke={stroke} stroke-width={sw}/>
      </>
    )}
    {kind === 'dual' && (
      <>
        <rect x="44"  y="34" width="50" height="82" stroke={stroke} stroke-width={sw} fill="none"/>
        <rect x="106" y="34" width="50" height="82" stroke={stroke} stroke-width={sw} fill="none"/>
        <line x1="52"  y1="50" x2="86"  y2="50" stroke={stroke} stroke-width={sw}/>
        <line x1="52"  y1="62" x2="86"  y2="62" stroke={stroke} stroke-width={sw}/>
        <line x1="114" y1="50" x2="148" y2="50" stroke={stroke} stroke-width={sw}/>
        <line x1="114" y1="62" x2="148" y2="62" stroke={stroke} stroke-width={sw}/>
        <rect x="44"  y="34" width="50" height="10" fill={accent} opacity="0.85"/>
        <rect x="106" y="34" width="50" height="10" fill={fillSoft}/>
      </>
    )}
    {kind === 'doc' && (
      <>
        <rect x="62" y="28" width="76" height="98" stroke={stroke} stroke-width={sw} fill="none"/>
        {[44,56,68,80,92,104].map((y,i) => (
          <>
            <rect x="70" y={y} width="6" height="6" stroke={stroke} stroke-width={sw} fill="none"/>
            <line x1="80" y1={y+3} x2="130" y2={y+3} stroke={stroke} stroke-width={sw} opacity="0.5"/>
            {i < 3 && <path d={`M 71 ${y+3} L 73 ${y+5} L 75 ${y+1}`} stroke={accent} stroke-width="1.4" fill="none"/>}
          </>
        ))}
      </>
    )}
    {kind === 'screen' && (
      <>
        <rect x="68" y="22" width="64" height="106" rx="4" stroke={stroke} stroke-width={sw} fill="none"/>
        <rect x="74" y="32" width="52" height="6" fill={accent} opacity="0.85"/>
        <line x1="74" y1="46" x2="116" y2="46" stroke={stroke} stroke-width={sw}/>
        <line x1="74" y1="54" x2="126" y2="54" stroke={stroke} stroke-width={sw}/>
        <line x1="74" y1="62" x2="110" y2="62" stroke={stroke} stroke-width={sw}/>
        <rect x="74" y="78" width="52" height="18" fill={fillSoft}/>
        <rect x="78" y="84" width="32" height="6" fill={accent} opacity="0.85"/>
      </>
    )}
    <rect x="0" y="0" width="200" height="150" fill="url(#inner-light)" style="pointer-events:none"/>
    <defs>
      <radialGradient id="inner-light" cx="50%" cy="45%" r="50%">
        <stop offset="0%" stop-color="white" stop-opacity="0.18"/>
        <stop offset="100%" stop-color="white" stop-opacity="0"/>
      </radialGradient>
    </defs>
  </svg>
</div>

<style>
  .krk-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .krk-thumb svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
