---
<footer class="krk-footer">
  <div class="krk-footer-inner">
    <div>
      <div class="krk-footer-logo">KRK CHECKER <span>·</span></div>
      <div class="krk-footer-copy">(c) 2026 krk.team · 서울특별시</div>
    </div>
    <nav class="krk-footer-links">
      <a href="https://checker.krk.team">제품</a>
      <a href="https://checker.krk.team/#pricing">가격</a>
      <a href="/">블로그</a>
      <a href="https://checker.krk.team/terms">이용약관</a>
      <a href="https://checker.krk.team/privacy">개인정보처리방침</a>
    </nav>
  </div>
</footer>

<style>
  .krk-footer {
    background: #0F0F12;
    color: rgba(255,255,255,0.55);
    padding: 36px 40px 28px;
    font-size: 12px;
    letter-spacing: -0.005em;
    margin-top: auto;
  }
  .krk-footer-inner {
    max-width: 1320px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .krk-footer-logo {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .krk-footer-logo span { color: #0CA4F9; }
  .krk-footer-copy { margin-top: 6px; font-size: 11px; }
  .krk-footer-links {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
    font-size: 11.5px;
  }
  .krk-footer-links a {
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color 160ms;
  }
  .krk-footer-links a:first-child { color: rgba(255,255,255,0.7); }
  .krk-footer-links a:hover { color: #fff; }
  @media (max-width: 760px) {
    .krk-footer { padding: 28px 20px 22px; }
    .krk-footer-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
