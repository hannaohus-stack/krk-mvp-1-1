---
import { getCollection, type CollectionEntry } from 'astro:content'
import Base from '@/layouts/Base.astro'
import Nav from '@/components/Nav.astro'
import Footer from '@/components/Footer.astro'
import Thumb from '@/components/Thumb.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }))
}

interface Props { post: CollectionEntry<'posts'> }
const { post } = Astro.props
const { Content, headings } = await post.render()

const CAT_KO: Record<string, string> = {
  label: '라벨 기준', ingredient: '원재료·알레르기', packaging: '분리배출·포장',
  filing: '품목제조보고', cases: '브랜드 사례', updates: 'KRK 업데이트',
}

const allPosts = await getCollection('posts')
const others = allPosts.filter(p => p.slug !== post.slug)
// Static shuffle based on slug hash for consistency
const seed = post.slug.split('').reduce((a, c) => a + c.charCodeAt(0), 0)
const shuffled = [...others].sort((a, b) => {
  const ha = (seed * a.slug.charCodeAt(0)) % 97
  const hb = (seed * b.slug.charCodeAt(0)) % 97
  return ha - hb
})
const related = shuffled.slice(0, 3)
const tocItems = headings.filter(h => h.depth === 2)
---

<Base
  title={`${post.data.title} — KRK Checker 블로그`}
  description={post.data.summary}
  canonicalUrl={`https://blog.krk.team/${post.slug}`}
>
  <div class="page">
    <Nav />

    <!-- Article Header -->
    <header class="article-header">
      <div class="header-inner">
        <a href="/" class="back-link">← BACK TO BLOG</a>
        <div class="header-eyebrow">
          <span class="breath-line"></span>
          <span>ARTICLE · {post.data.num}</span>
          <span class="sep">·</span>
          <span class="cat-label">{CAT_KO[post.data.cat]?.toUpperCase()}</span>
        </div>
        <h1 class="article-title">{post.data.title}</h1>
        <div class="header-grid">
          <p class="article-summary">{post.data.summary}</p>
          <div class="article-meta-grid">
            <span class="meta-label">발행일</span>
            <span class="meta-val">{post.data.date}</span>
            <span class="meta-label">읽는 시간</span>
            <span class="meta-val">{post.data.time}분</span>
            <span class="meta-label">기준 출처</span>
            <span class="meta-val">{post.data.src.join(' · ')}</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero Band — full bleed -->
    <div class="hero-band">
      <Thumb kind={post.data.thumb} tone="dark" />
    </div>

    <!-- Body + TOC -->
    <div class="body-wrap">
      <div class="body-grid">
        <article class="article-body krk-prose">
          <Content />
        </article>

        {tocItems.length > 0 && (
          <aside class="toc-sidebar">
            <div class="toc-sticky">
              <div class="toc-label">CONTENTS — {String(tocItems.length).padStart(2,'0')}</div>
              <ul class="toc-list">
                {tocItems.map((h, i) => (
                  <li class="toc-item">
                    <span class="toc-num">{String(i+1).padStart(2,'0')}</span>
                    <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )}
      </div>
    </div>

    <!-- CTA Band — full bleed, outside body-grid -->
    <div class="article-cta">
      <div class="cta-veil"></div>
      <div class="cta-inner">
        <div class="cta-eyebrow"><span class="cta-dash"></span>START</div>
        <div class="cta-title">이 글의 기준대로 라벨을 검토하고 싶다면,<br/>3분이면 충분합니다.</div>
        <div class="cta-sub">KRK Checker가 표시사항을 자동으로 점검합니다. 결과는 자율 점검 참고용입니다.</div>
        <a href="https://checker.krk.team" class="cta-btn">KRK Checker 시작하기 →</a>
      </div>
    </div>

    <!-- Related Articles -->
    <section class="related-section">
      <div class="related-inner">
        <div class="related-header">
          <div class="related-title">관련 글</div>
          <a href="/" class="related-all">전체 보기 →</a>
        </div>
        <div class="related-grid">
          {related.map(art => (
            <a href={`/${art.slug}`} class="related-card">
              <Thumb kind={art.data.thumb} tone="light" />
              <div class="related-cat">{CAT_KO[art.data.cat]}</div>
              <div class="related-card-title">{art.data.title}</div>
              <div class="related-meta">{art.data.time}분 · 기준 {art.data.src[0]}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Base>

<style>
  .page { display: flex; flex-direction: column; min-height: 100vh; }

  /* Header */
  .article-header { padding-top: 70px; background: #fff; }
  .header-inner {
    max-width: 1320px; margin: 0 auto;
    padding: 72px 48px 40px;
  }
  .back-link {
    display: inline-flex; align-items: center;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(10,10,11,0.40); text-decoration: none;
    margin-bottom: 28px;
    transition: color 160ms;
  }
  .back-link:hover { color: #0A0A0B; }
  .header-eyebrow {
    display: flex; align-items: center; gap: 18px;
    margin-bottom: 22px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(10,10,11,0.40);
  }
  .breath-line {
    display: inline-block; width: 32px; height: 1px;
    background: #0CA4F9; flex-shrink: 0;
  }
  .sep { color: rgba(10,10,11,0.20); }
  .cat-label { color: #002D72; }
  .article-title {
    margin: 0 0 32px;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 600;
    letter-spacing: -0.033em;
    color: #0A0A0B;
    line-height: 1.12;
    max-width: 900px;
  }
  .header-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: start;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(10,10,11,0.10);
    padding-bottom: 32px;
  }
  .article-summary {
    margin: 0;
    font-size: clamp(14px, 1.4vw, 17px);
    color: rgba(10,10,11,0.65);
    line-height: 1.65;
    letter-spacing: -0.005em;
    max-width: 580px;
  }
  .article-meta-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 16px;
    font-size: 12px;
    align-content: start;
  }
  .meta-label {
    font-family: 'Inter', system-ui, sans-serif;
    color: rgba(10,10,11,0.40);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .meta-val { color: #0A0A0B; }

  /* Hero Band — truly full bleed */
  .hero-band {
    background: #002D72;
    width: 100%;
    aspect-ratio: 32/10;
    position: relative;
    overflow: hidden;
  }

  /* Body */
  .body-wrap { padding: 72px 48px 0; }
  .body-grid {
    max-width: 1320px; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 64px;
    align-items: start;
  }
  .article-body { max-width: 720px; padding-bottom: 96px; }

  /* TOC */
  .toc-sidebar {}
  .toc-sticky {
    position: sticky; top: 90px;
    border-top: 1px solid rgba(10,10,11,0.10);
    padding-top: 18px;
  }
  .toc-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(10,10,11,0.35);
    margin-bottom: 14px;
  }
  .toc-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 9px;
  }
  .toc-item {
    display: grid; grid-template-columns: 28px 1fr; gap: 10px;
    font-size: 12.5px; line-height: 1.4; letter-spacing: -0.01em;
  }
  .toc-num {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 10.5px; color: rgba(10,10,11,0.30);
    padding-top: 2px;
  }
  .toc-link { color: rgba(10,10,11,0.60); text-decoration: none; transition: color 160ms; }
  .toc-link:hover { color: #0A0A0B; }

  /* CTA — full bleed at page level */
  .article-cta {
    position: relative; overflow: hidden;
    background: #002D72; color: #fff;
    padding: 64px 48px;
  }
  .cta-veil {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(60% 80% at 100% 0%, rgba(12,164,249,0.25), transparent 60%);
  }
  .cta-inner {
    position: relative; z-index: 1;
    max-width: 1320px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 22px;
    max-width: 720px;
  }
  .cta-eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.6);
  }
  .cta-dash {
    display: inline-block; width: 24px; height: 1px;
    background: #0CA4F9; flex-shrink: 0;
  }
  .cta-title {
    font-size: clamp(22px, 2.5vw, 30px);
    font-weight: 600; line-height: 1.3;
    letter-spacing: -0.025em;
  }
  .cta-sub {
    font-size: 14px; color: rgba(255,255,255,0.7);
    letter-spacing: -0.005em; line-height: 1.6;
  }
  .cta-btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 15px 28px;
    background: #fff; color: #0A0A0B;
    text-decoration: none;
    font-size: 14px; font-weight: 600;
    letter-spacing: -0.005em;
    align-self: flex-start;
    transition: opacity 160ms;
  }
  .cta-btn:hover { opacity: 0.85; }

  /* Related */
  .related-section { padding: 88px 48px 96px; }
  .related-inner { max-width: 1320px; margin: 0 auto; }
  .related-header {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 32px; padding-bottom: 14px;
    border-bottom: 1px solid rgba(10,10,11,0.10);
  }
  .related-title {
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 700; letter-spacing: -0.022em;
    color: #0A0A0B;
  }
  .related-all {
    font-size: 12px; color: rgba(10,10,11,0.40);
    text-decoration: none; transition: color 160ms;
  }
  .related-all:hover { color: #0A0A0B; }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .related-card {
    display: flex; flex-direction: column; gap: 12px;
    text-decoration: none; color: inherit;
    transition: opacity 160ms;
  }
  .related-card:hover { opacity: 0.8; }
  .related-cat {
    font-size: 11.5px; color: #002D72;
    letter-spacing: 0.01em; margin-top: 2px;
  }
  .related-card-title {
    font-size: clamp(14px, 1.3vw, 16px);
    font-weight: 600; line-height: 1.4;
    letter-spacing: -0.015em; color: #0A0A0B;
  }
  .related-meta {
    font-size: 11.5px; color: rgba(10,10,11,0.40);
    margin-top: auto; padding-top: 4px;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .header-grid { grid-template-columns: 1fr; gap: 24px; }
    .body-grid { grid-template-columns: 1fr; }
    .toc-sidebar { display: none; }
    .hero-band { aspect-ratio: 16/7; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .header-inner { padding: 40px 20px 28px; }
    .body-wrap { padding: 40px 20px 0; }
    .article-cta { padding: 40px 20px; }
    .related-section { padding: 56px 20px 64px; }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
