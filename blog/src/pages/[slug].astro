---
import { getCollection, type CollectionEntry } from 'astro:content'
import Base from '@/layouts/Base.astro'
import Nav from '@/components/Nav.astro'
import Footer from '@/components/Footer.astro'
import Thumb from '@/components/Thumb.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }))
}

interface Props { post: CollectionEntry<'posts'> }
const { post } = Astro.props
const { Content } = await post.render()

const CAT_KO: Record<string, string> = {
  label: '라벨 기준', ingredient: '원재료·알레르기', packaging: '분리배출·포장',
  filing: '품목제조보고', cases: '브랜드 사례', updates: 'KRK 업데이트',
}

const OG_IMAGES: Record<string, string> = {
  label:      'https://blog.krk.team/og-label.png',
  ingredient: 'https://blog.krk.team/og-ingredient.png',
  packaging:  'https://blog.krk.team/og-packaging.png',
  filing:     'https://blog.krk.team/og-filing.png',
  updates:    'https://blog.krk.team/og-updates.png',
}
const ogImage = OG_IMAGES[post.data.cat] ?? 'https://blog.krk.team/og-default.png'

const allPosts = await getCollection('posts')
const others = allPosts.filter(p => p.slug !== post.slug)
const seed = post.slug.split('').reduce((a, c) => a + c.charCodeAt(0), 0)
const shuffled = [...others].sort((a, b) => {
  const ha = (seed * a.slug.charCodeAt(0)) % 97
  const hb = (seed * b.slug.charCodeAt(0)) % 97
  return ha - hb
})
const related = shuffled.slice(0, 3)

const canonicalUrl = `https://blog.krk.team/${post.slug}`
const dateISO = post.data.date.replace(/\./g, '-')
const postKeywords = (post.data.keywords ?? []).join(', ')

const articleSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.summary,
  datePublished: dateISO,
  dateModified: dateISO,
  author: {
    '@type': 'Organization',
    name: '주식회사 맛차차',
    url: 'https://krk.team',
  },
  publisher: {
    '@type': 'Organization',
    name: 'KRK Checker',
    logo: { '@type': 'ImageObject', url: 'https://blog.krk.team/logo.png' },
  },
  mainEntityOfPage: canonicalUrl,
  image: ogImage,
  articleSection: CAT_KO[post.data.cat] ?? post.data.cat,
  ...(postKeywords ? { keywords: postKeywords } : {}),
}

function parseFAQ(body: string): Array<{ q: string; a: string }> {
  const sectionMatch = body.match(/##\s*자주\s*묻는\s*질문([\s\S]*?)(?=\n##|\n---|\s*$)/)
  if (!sectionMatch) return []
  const section = sectionMatch[1]
  const faqs: Array<{ q: string; a: string }> = []
  const blocks = section.split(/\n\n(?=\*\*Q\.)/)
  for (const block of blocks) {
    const qMatch = block.match(/^\*\*Q\.\s*(.*?)\*\*\s*\n+([\s\S]+)$/)
    if (!qMatch) continue
    const q = qMatch[1].trim()
    const a = qMatch[2].trim()
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/\n+/g, ' ')
    if (q && a) faqs.push({ q, a })
  }
  return faqs
}

const faqs = parseFAQ(post.body)
const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    }
  : null
---

<Base
  title={`${post.data.title} — KRK Checker 블로그`}
  description={post.data.summary}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <div class="page">
    <Nav />

    <!-- Article Header -->
    <header class="article-header">
      <div class="header-inner">
        <a href="/" class="back-link">← 블로그</a>
        <span class="cat-pill">{CAT_KO[post.data.cat]}</span>
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-meta">{post.data.date} · {post.data.time}분</p>
      </div>
    </header>

    <!-- Hero Band -->
    <div class="hero-band">
      <Thumb kind={post.data.thumb} tone="dark" />
    </div>

    <!-- Body -->
    <div class="body-wrap">
      <article class="article-body krk-prose">
        <Content />
      </article>
    </div>

    <!-- Author -->
    <div class="author-wrap">
      <p class="author-line">작성 KRK Checker 팀 · 검토 Hanna Oh · 기준 {post.data.src.join(' · ')}</p>
    </div>

    <!-- CTA -->
    <div class="article-cta">
      <div class="cta-inner">
        <p class="cta-text">라벨 확정 전, 3분이면 충분합니다.</p>
        <a href="https://checker.krk.team" class="cta-btn">KRK Checker 시작하기 →</a>
      </div>
    </div>

    <!-- Related Articles -->
    <section class="related-section">
      <div class="related-inner">
        <div class="related-header">
          <span class="related-title">관련 글</span>
          <a href="/" class="related-all">전체 보기 →</a>
        </div>
        <div class="related-grid">
          {related.map(art => (
            <a href={`/${art.slug}`} class="related-card">
              <Thumb kind={art.data.thumb} tone="light" />
              <div class="related-cat">{CAT_KO[art.data.cat]}</div>
              <div class="related-card-title">{art.data.title}</div>
              <div class="related-meta">{art.data.time}분 · {art.data.src[0]}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Base>

<style>
  .page { display: flex; flex-direction: column; min-height: 100vh; }

  /* ── Header ── */
  .article-header {
    padding-top: 70px;
    background: #fff;
  }
  .header-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .back-link {
    align-self: flex-start;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: rgba(10,10,11,0.38);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 160ms;
  }
  .back-link:hover { color: #0A0A0B; }
  .cat-pill {
    display: inline-block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #002D72;
    border: 0.5px solid rgba(0,45,114,0.3);
    padding: 4px 12px;
    border-radius: 40px;
    margin-bottom: 20px;
  }
  .article-title {
    margin: 0 0 18px;
    font-size: clamp(24px, 3.5vw, 40px);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: #0A0A0B;
    line-height: 1.18;
    max-width: 600px;
  }
  .article-meta {
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: rgba(10,10,11,0.38);
    letter-spacing: 0.02em;
    width: 100%;
  }

  /* ── Hero Band ── */
  .hero-band {
    background: #002D72;
    margin: 0 24px;
    border-radius: 16px;
    aspect-ratio: 32/10;
    position: relative;
    overflow: hidden;
  }

  /* ── Body ── */
  .body-wrap {
    padding: 64px 24px 0;
  }
  .article-body {
    max-width: 660px;
    margin: 0 auto;
    padding-bottom: 56px;
  }

  /* ── Author ── */
  .author-wrap {
    max-width: 660px;
    margin: 0 auto;
    padding: 0 24px 48px;
  }
  .author-line {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 11.5px;
    color: rgba(10,10,11,0.38);
    text-align: center;
    margin: 0;
  }

  /* ── CTA ── */
  .article-cta {
    padding: 48px 24px;
  }
  .cta-inner {
    max-width: 660px;
    margin: 0 auto;
    background: rgba(10,10,11,0.04);
    border-radius: 16px;
    padding: 64px 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .cta-text {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    color: #0A0A0B;
    letter-spacing: -0.025em;
    line-height: 1.3;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: #002D72;
    color: #fff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    border-radius: 40px;
    letter-spacing: -0.01em;
    transition: opacity 160ms;
  }
  .cta-btn:hover { opacity: 0.85; }

  /* ── Related ── */
  .related-section { padding: 72px 24px 88px; }
  .related-inner { max-width: 1080px; margin: 0 auto; }
  .related-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 28px;
  }
  .related-title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: #0A0A0B;
  }
  .related-all {
    font-size: 12px;
    color: rgba(10,10,11,0.40);
    text-decoration: none;
    transition: color 160ms;
  }
  .related-all:hover { color: #0A0A0B; }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    transition: opacity 160ms;
  }
  .related-card:hover { opacity: 0.75; }
  .related-cat {
    font-size: 11px;
    color: #002D72;
    letter-spacing: 0.02em;
  }
  .related-card-title {
    font-size: clamp(13px, 1.2vw, 15px);
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: -0.015em;
    color: #0A0A0B;
  }
  .related-meta {
    font-size: 11px;
    color: rgba(10,10,11,0.38);
    margin-top: auto;
    padding-top: 2px;
  }

  /* ── Responsive ── */
  @media (max-width: 760px) {
    .header-inner { padding: 40px 20px 28px; }
    .body-wrap { padding: 40px 20px 0; }
    .article-cta { padding: 32px 20px; }
    .cta-inner { padding: 32px 24px; border-radius: 12px; }
    .related-section { padding: 48px 20px 64px; }
    .related-grid { grid-template-columns: 1fr; }
    .hero-band { aspect-ratio: 16/7; margin: 0 16px; border-radius: 12px; }
  }
  @media (max-width: 1024px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

