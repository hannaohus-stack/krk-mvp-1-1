---
import { getCollection } from 'astro:content'
import Base from '@/layouts/Base.astro'
import Nav from '@/components/Nav.astro'
import Footer from '@/components/Footer.astro'
import Thumb from '@/components/Thumb.astro'

const allPosts = await getCollection('posts')
const posts = allPosts.sort((a, b) => b.data.num.localeCompare(a.data.num))
const featured = posts.find(p => p.data.featured) ?? posts[0]
const rest = posts.filter(p => p.slug !== featured.slug)

const CATEGORIES = [
  { id: 'all',        ko: '전체' },
  { id: 'label',      ko: '라벨 기준' },
  { id: 'ingredient', ko: '원재료·알레르기' },
  { id: 'packaging',  ko: '분리배출·포장' },
  { id: 'filing',     ko: '품목제조보고' },
  { id: 'cases',      ko: '브랜드 사례' },
  { id: 'updates',    ko: 'KRK 업데이트' },
]

const CAT_KO = Object.fromEntries(CATEGORIES.map(c => [c.id, c.ko]))
---

<Base title="KRK Checker 블로그 — 판매 전 확인해야 할 라벨 기준">
  <div class="page">
    <Nav currentPath="/" />

    <header class="page-header">
      <div class="header-inner">
        <div class="eyebrow">
          <span class="eyebrow-line"></span>
          INSIGHTS · KRK CHECKER
        </div>
        <div class="header-grid">
          <h1 class="page-title">라벨도,<br/><span class="heritage">브랜드의 일부니까.</span></h1>
          <p class="page-sub">스몰 식품 브랜드가 판매 전 알아야 할 표시 기준을 정돈된 가이드로 정리합니다. 모든 글은 출처를 함께 표기합니다.</p>
        </div>
      </div>
    </header>

    <section class="featured-section">
      <a href={`/${featured.slug}`} class="featured-card">
        <div class="featured-veil"></div>
        <div class="featured-body">
          <div class="featured-left">
            <div class="featured-eyebrow"><span class="featured-dash"></span>FEATURED · {featured.data.num}</div>
            <h2 class="featured-title">{featured.data.title}</h2>
            <p class="featured-summary">{featured.data.summary}</p>
            <div class="featured-meta">
              <span>{CAT_KO[featured.data.cat]}</span>
              <span class="dot">·</span>
              <span>{featured.data.time}분</span>
              <span class="dot">·</span>
              <span>기준 {featured.data.src[0]}</span>
            </div>
          </div>
          <div class="featured-thumb-wrap">
            <Thumb kind={featured.data.thumb} tone="dark" />
          </div>
        </div>
      </a>
    </section>

    <div class="filter-bar">
      <div class="filter-inner">
        <span class="filter-label">FILTER —</span>
        <div class="cat-tabs" id="cat-tabs">
          {CATEGORIES.map(c => (
            <button type="button" class:list={['cat-btn', { active: c.id === 'all' }]} data-cat={c.id}>{c.ko}</button>
          ))}
        </div>
        <span class="article-count" id="article-count">{String(rest.length).padStart(2, '0')} ARTICLES</span>
      </div>
    </div>

    <main class="grid-section">
      <div class="article-grid" id="article-grid">
        {rest.map(post => (
          <div class="grid-cell" data-cat={post.data.cat}>
            <a href={`/${post.slug}`} class="article-card">
              <Thumb kind={post.data.thumb} tone="light" />
              <div class="card-body">
                <div class="card-eyebrow"><span class="card-num">{post.data.num}</span><span>{CAT_KO[post.data.cat]}</span></div>
                <h3 class="card-title">{post.data.title}</h3>
                <p class="card-summary">{post.data.summary}</p>
                <div class="card-meta"><span>{post.data.time}분</span><span class="dot">·</span><span>기준 {post.data.src[0]}</span></div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </main>

    <section class="cta-band">
      <div class="cta-inner">
        <div>
          <div class="cta-eyebrow">READY?</div>
          <div class="cta-title">지금 라벨을 점검해보세요.</div>
          <div class="cta-sub">3분이면 자율 점검이 끝납니다. 결과는 참고용입니다.</div>
        </div>
        <a href="https://checker.krk.team" class="cta-btn">KRK Checker 시작하기 →</a>
      </div>
    </section>

    <Footer />
  </div>
</Base>

<script>
  const tabs = document.querySelectorAll('.cat-btn')
  const cells = document.querySelectorAll('.grid-cell')
  const counter = document.getElementById('article-count')
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.cat ?? 'all'
      tabs.forEach(t => t.classList.remove('active'))
      tab.classList.add('active')
      let visible = 0
      cells.forEach(cell => {
        const match = cat === 'all' || cell.dataset.cat === cat
        cell.style.display = match ? '' : 'none'
        if (match) visible++
      })
      if (counter) counter.textContent = String(visible).padStart(2, '0') + ' ARTICLES'
    })
  })
</script>

<style>
  .page { display: flex; flex-direction: column; min-height: 100vh; }
  .page-header { padding-top: 70px; background: #fff; }
  .header-inner { max-width: 1320px; margin: 0 auto; padding: 88px 48px 24px; }
  .eyebrow { display: flex; align-items: center; gap: 18px; margin-bottom: 24px; font-family: 'Inter', system-ui, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(10,10,11,0.45); }
  .eyebrow-line { display: inline-block; width: 32px; height: 1px; background: #0CA4F9; flex-shrink: 0; }
  .header-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 64px; align-items: end; }
  .page-title { margin: 0; font-size: clamp(34px, 5vw, 64px); font-weight: 600; letter-spacing: -0.035em; line-height: 1.05; color: #0A0A0B; }
  .heritage { color: #002D72; }
  .page-sub { margin: 0; padding-bottom: 8px; font-size: clamp(13px, 1.3vw, 15px); color: rgba(10,10,11,0.65); line-height: 1.65; letter-spacing: -0.005em; max-width: 420px; }
  .featured-section { margin-top: 32px; }
  .featured-card { display: block; background: #002D72; color: #fff; text-decoration: none; padding: 64px; position: relative; overflow: hidden; transition: opacity 200ms; }
  .featured-card:hover { opacity: 0.95; }
  .featured-veil { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(80% 80% at 90% 10%, rgba(12,164,249,0.22), transparent 60%), radial-gradient(60% 60% at 0% 100%, rgba(255,255,255,0.05), transparent 70%); }
  .featured-body { position: relative; z-index: 1; max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: center; }
  .featured-left { display: flex; flex-direction: column; gap: 28px; }
  .featured-eyebrow { display: inline-flex; align-items: center; gap: 12px; font-family: 'Inter', system-ui, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.7); }
  .featured-dash { display: inline-block; width: 24px; height: 1px; background: #0CA4F9; flex-shrink: 0; }
  .featured-title { margin: 0; font-size: clamp(28px, 3.5vw, 44px); font-weight: 600; line-height: 1.22; letter-spacing: -0.028em; color: #fff; }
  .featured-summary { margin: 0; font-size: clamp(13px, 1.3vw, 16px); color: rgba(255,255,255,0.75); line-height: 1.65; letter-spacing: -0.005em; max-width: 560px; }
  .featured-meta { display: flex; align-items: center; gap: 14px; font-size: 12px; color: rgba(255,255,255,0.55); margin-top: 8px; }
  .featured-thumb-wrap { aspect-ratio: 4/3; background: radial-gradient(120% 90% at 30% 30%, #001D4A 0%, #00255E 50%, #000B1F 100%); border: 1px solid rgba(255,255,255,0.1); position: relative; overflow: hidden; }
  .filter-bar { border-bottom: 1px solid rgba(10,10,11,0.10); background: #fff; }
  .filter-inner { max-width: 1320px; margin: 0 auto; padding: 24px 48px; display: flex; align-items: center; gap: 18px; }
  .filter-label { font-family: 'Inter', system-ui, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(10,10,11,0.45); flex-shrink: 0; }
  .cat-tabs { display: flex; align-items: center; gap: 28px; overflow-x: auto; scrollbar-width: none; flex: 1; min-width: 0; }
  .cat-tabs::-webkit-scrollbar { display: none; }
  .cat-btn { background: transparent; border: none; cursor: pointer; padding: 0 0 6px; font-family: 'Pretendard', system-ui, sans-serif; font-size: 15px; font-weight: 400; color: rgba(10,10,11,0.45); border-bottom: 2px solid transparent; letter-spacing: -0.01em; white-space: nowrap; transition: color 160ms, border-color 160ms, font-weight 160ms; }
  .cat-btn.active, .cat-btn:hover { color: #0A0A0B; font-weight: 600; }
  .cat-btn.active { border-bottom-color: #002D72; }
  .article-count { font-family: 'Inter', system-ui, sans-serif; font-size: 11px; font-weight: 500; color: rgba(10,10,11,0.45); letter-spacing: 0.04em; flex-shrink: 0; }
  .grid-section { flex: 1; }
  .article-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(10,10,11,0.10); border-bottom: 1px solid rgba(10,10,11,0.10); }
  .grid-cell { background: #fff; }
  .article-card { display: flex; flex-direction: column; text-decoration: none; color: inherit; height: 100%; transition: background 160ms; }
  .article-card:hover { background: #FAFAFA; }
  .card-body { padding: 4px 18px 22px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .card-eyebrow { display: flex; align-items: center; gap: 8px; font-size: 11.5px; font-weight: 500; color: #002D72; }
  .card-num { font-family: 'Inter', system-ui, sans-serif; font-weight: 600; color: rgba(10,10,11,0.45); }
  .card-title { margin: 0; font-size: clamp(15px, 1.4vw, 17.5px); font-weight: 600; line-height: 1.4; color: #0A0A0B; letter-spacing: -0.015em; }
  .card-summary { margin: 0; font-size: 13.5px; color: rgba(10,10,11,0.65); line-height: 1.55; letter-spacing: -0.01em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; flex: 1; }
  .card-meta { display: flex; align-items: center; gap: 8px; font-size: 11.5px; color: rgba(10,10,11,0.45); letter-spacing: -0.005em; }
  .dot { color: rgba(10,10,11,0.30); }
  .cta-band { background: #F6F9FD; padding: 64px 48px; }
  .cta-inner { max-width: 1320px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .cta-eyebrow { font-family: 'Inter', system-ui, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(10,10,11,0.45); margin-bottom: 12px; }
  .cta-title { font-size: clamp(22px, 2.5vw, 28px); font-weight: 600; letter-spacing: -0.022em; color: #0A0A0B; line-height: 1.3; }
  .cta-sub { font-size: 14px; color: rgba(10,10,11,0.65); margin-top: 6px; letter-spacing: -0.005em; }
  .cta-btn { padding: 16px 28px; background: #0A0A0B; color: #fff; text-decoration: none; font-size: 14px; font-weight: 600; letter-spacing: -0.005em; white-space: nowrap; display: inline-flex; align-items: center; gap: 10px; transition: opacity 160ms; }
  .cta-btn:hover { opacity: 0.85; }
  @media (max-width: 1024px) {
    .header-grid { grid-template-columns: 1fr; gap: 18px; }
    .featured-body { grid-template-columns: 1fr; }
    .featured-thumb-wrap { display: none; }
    .article-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .header-inner { padding: 40px 20px 20px; }
    .featured-card { padding: 40px 24px 32px; }
    .filter-inner { padding: 16px 20px; }
    .filter-label { display: none; }
    .article-grid { grid-template-columns: 1fr; }
    .article-count { display: none; }
    .cta-band { padding: 40px 20px; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
